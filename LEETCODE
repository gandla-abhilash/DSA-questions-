class Solution {
    public int firstMatchingIndex(String s) {
        int count = 0;
        for(int i = 0;i<s.length();i++){
            char c1 = s.charAt(i);
            char c2 = s.charAt(s.length()-i-1);
            if(c1 == c2){
                return i;
            }
        }
        return -1;
    }
}
