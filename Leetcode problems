    public String[] findRelativeRanks(int[] score) {
        int N = score.length;
        int[] sorted = score.clone();
        Arrays.sort(sorted);
        Map<Integer,String> result = new HashMap<>();
        for(int i = N-1;i>=0;i--){
            int rank = N-i;
            if(rank == 1){
                result.put(sorted[i],"Gold Medal");
